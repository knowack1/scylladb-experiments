INSERT INTO articles (article_id, title, article, embedding) VALUES (v0000000-0000-4000-8000-000000000001, 'Photosynthesis', 'Green plants, algae, and some bacteria feed themselves by capturing light with the pigment chlorophyll in their leaves. They take in carbon dioxide and water and build sugars that nourish the organism, releasing oxygen as a by-product.', [-0.071183, 0.062259, -0.026291, 0.036765, 0.067864, 0.023844, 0.053936, -0.060483, 0.056516, 0.056474, 0.053083, -0.089102, -0.021468, -0.034203, 0.014067, 0.083320, -0.049295, 0.044672, -0.073988, -0.040342, 0.065345, 0.034259, -0.064767, -0.041342, -0.021074, -0.006955, -0.081761, -0.031669, 0.049574, -0.057510, 0.011564, 0.009894, 0.034370, -0.000302, 0.024522, 0.097123, 0.027111, -0.159192, 0.009697, 0.036826, -0.037366, -0.025706, 0.009037, 0.060547, -0.083835, 0.017328, 0.049989, 0.063709, -0.074134, -0.163560, -0.044440, -0.039593, -0.097407, 0.016802, -0.004684, 0.018095, 0.028231, -0.024485, 0.045371, -0.083689, 0.061898, -0.072198, 0.008788, 0.022675, -0.017443, 0.017013, -0.083877, -0.008170, 0.007489, -0.088690, -0.057865, 0.001958, 0.025464, 0.039096, -0.026030, 0.007659, 0.035901, -0.024564, -0.025573, 0.034481, 0.034336, 0.039039, -0.044492, 0.051639, 0.097414, -0.003487, 0.021258, 0.033469, -0.022620, 0.004732, -0.064225, -0.027045, -0.020380, -0.024010, -0.111845, 0.035040, 0.053237, -0.129597, 0.055432, -0.036935, 0.028146, 0.051430, -0.012716, -0.075866, -0.040010, -0.039088, -0.061080, 0.078929, -0.015879, 0.030718, -0.031746, 0.046177, -0.079786, 0.034791, 0.027477, 0.007646, 0.068616, -0.020156, -0.040687, 0.021621, -0.026253, -0.044214, -0.029967, -0.011315, -0.034949, -0.011494, -0.070420, 0.000000, 0.067826, -0.058892, 0.029575, -0.015713, 0.032202, -0.068441, -0.004580, -0.031732, 0.015043, -0.029716, -0.044285, -0.041684, 0.016678, 0.075128, 0.017483, 0.017165, -0.055930, -0.019739, -0.024539, 0.102257, -0.007938, 0.048224, 0.009239, 0.027706, 0.058146, -0.000018, 0.023549, -0.0314